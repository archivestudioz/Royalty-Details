DATABASE_URL=postgres://user:pass@host/db
SESSION_SECRET=replace-with-32+-char-random-string
ALLOWED_ORIGIN=https://royaltydetails.example

# Welcome email (Resend) — optional. If RESEND_API_KEY is unset, the email step is skipped.
RESEND_API_KEY=
FROM_EMAIL=Royalty Details <hello@royaltydetails.com>
REPLY_TO_EMAIL=info@royaltydetails.com

# Mapbox — proximity-aware scheduling. If MAPBOX_TOKEN is unset, bookings fall back to a fixed 4h block.
MAPBOX_TOKEN=
HOMEBASE_ADDRESS=275 Beech Street, Hackensack, NJ 07601
